{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash($HOME/.claude/hooks/inject.sh *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh PreToolUse PLAN.md --once on_plan"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh PostToolUse EXIT_PLAN.md"
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh PostToolUse TASK_DONE.md --when '.tool_input.status == \"completed\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh UserPromptSubmit PLAN.md --once on_plan --when '.permission_mode == \"plan\"'"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true
}
