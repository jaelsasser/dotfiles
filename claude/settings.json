{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash($HOME/.claude/hooks/inject.sh *)",
      "Bash(ls -t ~/.claude/plans/*.md 2>/dev/null | head -1)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh PreToolUse $HOME/.claude/hooks/PLAN.md"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh PostToolUse $HOME/.claude/hooks/EXIT_PLAN.md --no-once"
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh PostToolUse $HOME/.claude/hooks/TASK_DONE.md --no-once"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/inject.sh UserPromptSubmit $HOME/.claude/hooks/PLAN.md --permission_mode plan"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true
}
